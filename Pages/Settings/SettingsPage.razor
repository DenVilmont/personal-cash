@page "/settings"
@inherits PersonalCash.Shared.UiComponentBase

@using MudBlazor
@using System.Globalization

<AuthorizeView>
    <Authorized>
        <MudContainer Class="pa-6" MaxWidth="MaxWidth.Small">

            <MudText Typo="Typo.h5">@L["Settings"]</MudText>

            <MudPaper Class="pa-6 mt-4">

                <MudText Typo="Typo.h6">@L["Profile"]</MudText>

                <MudStack direction="Row" Spacing="2" alignitems="AlignItems.Center" Class="mt-2">
                    <MudAvatar Size="Size.Large">
                        @if (!string.IsNullOrWhiteSpace(AvatarSrc))
                        {
                            <MudImage Src="@AvatarSrc" Alt="avatar" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                        }
                    </MudAvatar>

                    <MudStack Spacing="1">
                        <div class="avatar-upload">
                            <MudButton Variant="Variant.Outlined" Disabled="_busy" Class="mt-2">
                                @L["ChangeAvatar"]
                            </MudButton>

                            <InputFile OnChange="OnAvatarSelected"
                                       accept="image/png,image/jpeg,image/webp"
                                       class="avatar-upload__input"
                                       disabled="@_busy" />
                        </div>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Error"
                                   Disabled="_busy || string.IsNullOrWhiteSpace(_settings.AvatarBase64)"
                                   OnClick="RemoveAvatarAsync">
                            @L["Remove"]
                        </MudButton>
                    </MudStack>
                </MudStack>

                <MudGrid Spacing="3" Class="mt-2">
                    <MudItem xs="12" sm="6" Class="d-flex">
                        <MudTextField Label="@L["FirstName"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="w-100"
                                      @bind-Value="_settings.FirstName" />
                    </MudItem>

                    <MudItem xs="12" sm="6" Class="d-flex">
                        <MudTextField Label="@L["LastName"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="w-100"
                                      @bind-Value="_settings.LastName" />
                    </MudItem>

                    <MudItem xs="12" Class="d-flex">
                        <MudSelect T="string"
                                   Label="@L["Language"]"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="w-100"
                                   @bind-Value="_settings.PreferredLanguage">
                            <MudSelectItem T="string" Value="@("en")">English</MudSelectItem>
                            <MudSelectItem T="string" Value="@("es")">Español</MudSelectItem>
                            <MudSelectItem T="string" Value="@("ru")">Русский</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" Class="d-flex">
                        <MudSelect T="string"
                                   Label="@L["DefaultCurrency"]"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="w-100"
                                   @bind-Value="_settings.PreferredCurrency">
                            <MudSelectItem T="string" Value="@("EUR")">EUR</MudSelectItem>
                            <MudSelectItem T="string" Value="@("USD")">USD</MudSelectItem>
                            <MudSelectItem T="string" Value="@("RUB")">RUB</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="_busy"
                                   OnClick="SaveAsync">
                            @L["Save"]
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Class="pa-6 mt-4">
                <MudText Typo="Typo.h6">Email</MudText>

                <MudText Class="mt-2">@L["Current"]: @_currentEmail</MudText>

                <MudTextField Label="@L["NewEmail"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="w-100 mt-3"
                              @bind-Value="_newEmail" />

                <MudButton Variant="Variant.Outlined"
                           Disabled="_busy"
                           Class="mt-2"
                           OnClick="ChangeEmailAsync">
                    @L["ChangeEmail"]
                </MudButton>
            </MudPaper>

        </MudContainer>
    </Authorized>

    <NotAuthorized>
        <MudContainer Class="pa-6" MaxWidth="MaxWidth.Small">
            <MudText Typo="Typo.h6">@L["PleaseLoginFirst"]</MudText>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>