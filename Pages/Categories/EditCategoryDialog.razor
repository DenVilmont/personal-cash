@inherits PersonalCash.Shared.UiComponentBase

<MudDialog ContentClass="edit-category-dialog__content"
           ActionsClass="edit-category-dialog__actions">
    <DialogContent>
        <MudStack Spacing="2" Class="edit-category-dialog__stack">
            <MudTextField Label="@L["Categories_Name"]"
                          @bind-Value="_name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Required="true"
                          RequiredError="@L["Categories_NameRequired_ValidationError"]" />
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">
            @L["Cancel"]
        </MudButton>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy" OnClick="SaveAsync">
            @L["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>