@page "/categories"
@inherits PersonalCash.Shared.UiComponentBase

@using Domain.Contracts
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav
@inject IDialogService DialogService

<AuthorizeView>
    <Authorized>
        <MudContainer Class="pa-6" MaxWidth="MaxWidth.False">

            <MudText Typo="Typo.h5">Categories</MudText>

            <MudGrid Spacing="3" Class="mt-2" alignitems="AlignItems.Stretch">
                <!-- LEFT: empty column (only on lg+) -->
                <MudItem xs="12" lg="4" Class="d-none d-lg-block">
                </MudItem>

                <!-- CENTER: 50% on lg+ (Add + Table stay here) -->
                <MudItem xs="12" lg="4">
                    <MudExpansionPanels Class="mb-6">
                        <MudExpansionPanel Expanded="false" Class="pa-4" elevation="2" Style="position: sticky; top: 88px;">
                            <TitleContent>
                                <div class="d-flex">
                                    <MudIcon Icon="@Icons.Material.Filled.AddCircle" class="mr-3"></MudIcon>
                                    <MudText Typo="Typo.h5">Add category</MudText>
                                </div>
                            </TitleContent>
                            <ChildContent>
                                <MudGrid Class="mt-2">
                                    <MudItem xs="12">
                                        <MudTextField Label="Name"
                                                      Required="true" RequiredError="Required"
                                                      @bind-Value="_name"
                                                      Variant="Variant.Outlined" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Disabled="_busy"
                                                   OnClick="AddAsync">
                                            Add
                                        </MudButton>

                                        <MudButton Class="ml-2"
                                                   Variant="Variant.Outlined"
                                                   Disabled="_busy"
                                                   OnClick="LoadAsync">
                                            Refresh
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                    <MudTable Items="_items" Dense="true" Hover="true" Class="mt-2" RowsPerPage="20" Filter="new Func<CategoryDto, bool>(SearchInTable)">
                        <ToolBarContent>
                                <MudText Typo="Typo.h6">My categories</MudText>
                                <MudSpacer />
                                <MudTextField @bind-Value="_searchString"
                                              Placeholder="Search"
                                              Variant="Variant.Text"
                                              Margin="Margin.Dense"
                                              Clearable="true"
                                              OnClearButtonClick="ClearSearch"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Search"
                                              IconSize="Size.Medium"
                                              Class="mt-0" />
                            </ToolBarContent>
                            <HeaderContent>
                                <MudTh>
                                <MudTableSortLabel SortBy="new Func<CategoryDto, object>(x => x.Name)">
                                        Name
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh Class="align-right"></MudTh>
                            </HeaderContent>

                            <RowTemplate Context="tx">
                                <MudTd>@tx.Name</MudTd>
                                <MudTd Class="align-right">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Disabled="_busy"
                                                   OnClick="@(async () => await OpenEditAsync(tx))" />

                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Disabled="_busy"
                                                   OnClick="@(async () => await ConfirmDeleteAsync(tx))" />
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                </MudItem>

                <MudItem xs="12" lg="4" Class="d-none d-lg-block">
                </MudItem>
            </MudGrid>
        </MudContainer>
    </Authorized>
</AuthorizeView>