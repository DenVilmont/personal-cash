@using Domain.Contracts
@using Domain.Enums
@using PersonalCash.Presentation.Icons

<MudExpansionPanels Class="transactions-add-form-root transactions-mobile-panel-group" Elevation="2">
    <MudExpansionPanel Expanded="false" Class="transactions-add-form-panel transactions-mobile-compact-panel">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.AddCircle" class="mr-2 transactions-mobile-compact-panel__icon"></MudIcon>
                <MudText Typo="Typo.h6" Class="transactions-mobile-compact-panel__text">@L["Add_transaction"]</MudText>
            </MudStack>
        </TitleContent>

        <ChildContent>
            <div class="transactions-mobile-panel-body">
                <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                    <MudItem xs="12" md="6" Class="d-flex">
                        <MudDatePicker Label="@L["Date"]"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Class="w-100"
                                       Date="OccurredOn"
                                       DateChanged="OnOccurredOnChanged" />
                    </MudItem>

                    <MudItem xs="12" md="6" Class="d-flex">
                        <MudSelect T="EntryType"
                                   Label="@L["Type"]"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="w-100"
                                   Value="EntryType"
                                   ValueChanged="OnEntryTypeChanged">
                            <MudSelectItem Value="Domain.Enums.EntryType.Income">
                                @Domain.Enums.EntryType.Income.ToLocalizedString(L)
                            </MudSelectItem>
                            <MudSelectItem Value="Domain.Enums.EntryType.Outcome">
                                @Domain.Enums.EntryType.Outcome.ToLocalizedString(L)
                            </MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        @if (Accounts.Count == 0)
                        {
                            <MudTextField T="Guid"
                                          Label="@L["Account"]"
                                          Disabled="true"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="w-100" />
                        }
                        else
                        {
                            <MudSelect T="Guid"
                                       Label="@L["Account"]"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Class="w-100"
                                       Value="AccountId"
                                       ValueChanged="OnAccountIdChanged">
                                @foreach (var a in Accounts)
                                {
                                    <MudSelectItem Value="@a.Id">
                                        <div class="icon-option">
                                            <MudIcon Icon="@AccountIconExtensions.FromDbKey(a.IconKey).GetIcon()" />
                                            @a.Name (@a.Currency)
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudItem>

                    <MudItem xs="12" md="6" Class="d-flex">
                        <MudNumericField T="decimal"
                                         Label="@L["Amount"]"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Class="w-100"
                                         HideSpinButtons="true"
                                         Adornment="Adornment.Start"
                                         AdornmentText="@Currency"
                                         Value="Amount"
                                         ValueChanged="OnAmountChanged" 
                                         Placeholder="0.00" />
                    </MudItem>

                    <MudItem xs="12" md="6" Class="d-flex">
                        @if (Categories.Count == 0)
                        {
                            <MudTextField T="Guid"
                                          Label="@L["Category"]"
                                          Disabled="true"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="w-100" />
                        }
                        else
                        {
                            <MudSelect T="Guid"
                                       Label="@L["Category"]"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Class="w-100"
                                       Value="CategoryId"
                                       ValueChanged="OnCategoryIdChanged">
                                @foreach (var c in Categories)
                                {
                                    <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudItem>

                    <MudItem xs="12" md="12" Class="d-flex">
                        <MudTextField T="string" 
                                      Label="@L["Note"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="3"
                                      Class="w-100"
                                      Value="Note"
                                      ValueChanged="OnNoteChanged" />
                    </MudItem>

                    <MudItem xs="12" md="6" Class="d-flex">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="w-100">
                            <MudSwitch T="bool"
                                       Label="@L["Is_For_Planning"]"
                                       Color="Color.Primary"
                                       Value="IsForPlanning"
                                       ValueChanged="OnIsForPlanningChanged" />
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12">
                        <div class="d-flex justify-space-between gap-1">
                            <MudButton Class="ml-2"
                                       Variant="Variant.Outlined"
                                       Disabled="Busy"
                                       OnClick="OnRefreshClicked">
                                @L["Refresh"]
                            </MudButton>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="Busy || AccountId == Guid.Empty || CategoryId == Guid.Empty"
                                       OnClick="OnAddClicked">
                                @L["Add"]
                            </MudButton>
                        </div>
                    </MudItem>
                </MudGrid>
            </div>
        </ChildContent>
    </MudExpansionPanel>
</MudExpansionPanels>