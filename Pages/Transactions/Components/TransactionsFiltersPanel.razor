@using Domain.Contracts
@using Domain.Enums

@if (IsCollapsible)
{
    <MudExpansionPanels Class="mb-6" Elevation="2">
        <MudExpansionPanel Expanded="false" KeepContentAlive="true" Class="pa-4">
            <TitleContent>
                <div class="d-flex">
                    <MudIcon Icon="@Icons.Material.Filled.FilterAlt" class="mr-3"></MudIcon>
                    <MudText Typo="Typo.h5">@L["Filters"]</MudText>
                </div>
            </TitleContent>

            <ChildContent>
                <MudStack Spacing="2" Class="mt-2">

                    <MudDatePicker Label="@L["Filter_Date_From"]"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="w-100"
                                   Date="FromDate"
                                   DateChanged="OnFromDateChanged"
                                   Clearable="true"
                                   AnchorOrigin="Origin.BottomRight"
                                   TransformOrigin="Origin.TopRight" />

                    <MudDatePicker Label="@L["Filter_Date_To"]"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="w-100"
                                   Date="ToDate"
                                   DateChanged="OnToDateChanged"
                                   Clearable="true"
                                   AnchorOrigin="Origin.BottomRight"
                                   TransformOrigin="Origin.TopRight" />

                    <MudSelect T="DateOnly?" Label="@L["Filter_Month"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="w-100"
                               Value="Month"
                               ValueChanged="OnMonthChanged"
                               Clearable="true"
                               OnClearButtonClick="OnMonthCleared">
                        <MudSelectItem T="DateOnly?" Value="@((DateOnly?)null)">
                            @L["Filter_Month_All"]
                        </MudSelectItem>

                        @foreach (var m in MonthOptions)
                        {
                            <MudSelectItem T="DateOnly?" Value="@m">
                                @FormatMonth(m)
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="Guid" Label="@L["Filter_Account"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="w-100"
                               MultiSelection="true"
                               SelectedValues="AccountIds"
                               SelectedValuesChanged="OnAccountIdsChanged"
                               MultiSelectionTextFunc="GetAccountSelectionText"
                               Clearable="true"
                               OnClearButtonClick="OnFiltersChanged">
                        @foreach (var a in Accounts)
                        {
                            <MudSelectItem T="Guid" Value="@a.Id">@a.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="EntryType?" Label="@L["Filter_Type"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="w-100"
                               Value="SelectedEntryType"
                               ValueChanged="OnEntryTypeChanged"
                               Clearable="true"
                               OnClearButtonClick="OnFiltersChanged">
                        <MudSelectItem T="EntryType?" Value="@((EntryType?)null)">@L["Filter_Type_All"]</MudSelectItem>
                        <MudSelectItem T="EntryType?" Value="@EntryType.Income">@EntryType.Income.ToLocalizedString(L)</MudSelectItem>
                        <MudSelectItem T="EntryType?" Value="@EntryType.Outcome">@EntryType.Outcome.ToLocalizedString(L)</MudSelectItem>
                    </MudSelect>

                    <MudSelect T="Guid" Label="@L["Filter_Category"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="w-100"
                               MultiSelection="true"
                               SelectedValues="CategoryIds"
                               SelectedValuesChanged="OnCategoryIdsChanged"
                               MultiSelectionTextFunc="GetCategorySelectionText"
                               Clearable="true"
                               OnClearButtonClick="OnFiltersChanged">
                        @foreach (var c in Categories)
                        {
                            <MudSelectItem T="Guid" Value="@c.Id">@c.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="bool?" Label="@L["Filter_Planned"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="w-100"
                               Value="IsForPlanning"
                               ValueChanged="OnIsForPlanningChanged"
                               Clearable="true"
                               OnClearButtonClick="OnFiltersChanged">
                        <MudSelectItem Value="@((bool?)null)">@L["Filter_Planned_All"]</MudSelectItem>
                        <MudSelectItem Value="@((bool?)true)">@L["Filter_PlannedOnly"]</MudSelectItem>
                        <MudSelectItem Value="@((bool?)false)">@L["Filter_ActualOnly"]</MudSelectItem>
                    </MudSelect>

                    <MudTextField T="string"
                                  Label="@L["Filter_NoteContains"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="w-100"
                                  Value="Note"
                                  ValueChanged="OnNoteChanged"
                                  Clearable="true"
                                  OnClearButtonClick="OnFiltersChanged" />

                    <MudNumericField T="decimal?" Label="@L["Filter_AmountFrom"]"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Class="w-100"
                                     Value="MinAmount"
                                     ValueChanged="OnMinAmountChanged"
                                     Clearable="true" />

                    <MudNumericField T="decimal?" Label="@L["Filter_AmountTo"]"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Class="w-100"
                                     Value="MaxAmount"
                                     ValueChanged="OnMaxAmountChanged"
                                     Clearable="true" />

                    <MudDivider Class="my-2" />

                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   Disabled="Busy"
                                   OnClick="OnClearClicked">
                            @L["Filter_Clear"]
                        </MudButton>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Disabled="Busy"
                                   OnClick="OnResetClicked">
                            @L["Filter_Reset"]
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="Busy"
                                   OnClick="OnSaveClicked">
                            @L["Filter_Save"]
                        </MudButton>
                    </MudStack>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
}
else
{
    <MudPaper Class="pa-4" Elevation="2">
        <div class="d-flex mb-4">
            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" class="mr-3"></MudIcon>
            <MudText Typo="Typo.h5">@L["Filters"]</MudText>
        </div>

        <MudStack Spacing="2" Class="mt-2">

            <MudDatePicker Label="@L["Filter_Date_From"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="w-100"
                           Date="FromDate"
                           DateChanged="OnFromDateChanged"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomRight"
                           TransformOrigin="Origin.TopRight" />

            <MudDatePicker Label="@L["Filter_Date_To"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="w-100"
                           Date="ToDate"
                           DateChanged="OnToDateChanged"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomRight"
                           TransformOrigin="Origin.TopRight" />

            <MudSelect T="DateOnly?" Label="@L["Filter_Month"]"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="w-100"
                       Value="Month"
                       ValueChanged="OnMonthChanged"
                       Clearable="true"
                       OnClearButtonClick="OnMonthCleared">
                <MudSelectItem T="DateOnly?" Value="@((DateOnly?)null)">
                    @L["Filter_Month_All"]
                </MudSelectItem>

                @foreach (var m in MonthOptions)
                {
                    <MudSelectItem T="DateOnly?" Value="@m">
                        @FormatMonth(m)
                    </MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="Guid" Label="@L["Filter_Account"]"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="w-100"
                       MultiSelection="true"
                       SelectedValues="AccountIds"
                       SelectedValuesChanged="OnAccountIdsChanged"
                       MultiSelectionTextFunc="GetAccountSelectionText"
                       Clearable="true"
                       OnClearButtonClick="OnFiltersChanged">
                @foreach (var a in Accounts)
                {
                    <MudSelectItem T="Guid" Value="@a.Id">@a.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="EntryType?" Label="@L["Filter_Type"]"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="w-100"
                       Value="SelectedEntryType"
                       ValueChanged="OnEntryTypeChanged"
                       Clearable="true"
                       OnClearButtonClick="OnFiltersChanged">
                <MudSelectItem T="EntryType?" Value="@((EntryType?)null)">@L["Filter_Type_All"]</MudSelectItem>
                <MudSelectItem T="EntryType?" Value="@EntryType.Income">@EntryType.Income.ToLocalizedString(L)</MudSelectItem>
                <MudSelectItem T="EntryType?" Value="@EntryType.Outcome">@EntryType.Outcome.ToLocalizedString(L)</MudSelectItem>
            </MudSelect>

            <MudSelect T="Guid" Label="@L["Filter_Category"]"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="w-100"
                       MultiSelection="true"
                       SelectedValues="CategoryIds"
                       SelectedValuesChanged="OnCategoryIdsChanged"
                       MultiSelectionTextFunc="GetCategorySelectionText"
                       Clearable="true"
                       OnClearButtonClick="OnFiltersChanged">
                @foreach (var c in Categories)
                {
                    <MudSelectItem T="Guid" Value="@c.Id">@c.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="bool?" Label="@L["Filter_Planned"]"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="w-100"
                       Value="IsForPlanning"
                       ValueChanged="OnIsForPlanningChanged"
                       Clearable="true"
                       OnClearButtonClick="OnFiltersChanged">
                <MudSelectItem Value="@((bool?)null)">@L["Filter_Planned_All"]</MudSelectItem>
                <MudSelectItem Value="@((bool?)true)">@L["Filter_PlannedOnly"]</MudSelectItem>
                <MudSelectItem Value="@((bool?)false)">@L["Filter_ActualOnly"]</MudSelectItem>
            </MudSelect>

            <MudTextField T="string"
                          Label="@L["Filter_NoteContains"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="w-100"
                          Value="Note"
                          ValueChanged="OnNoteChanged"
                          Clearable="true"
                          OnClearButtonClick="OnFiltersChanged" />

            <MudNumericField T="decimal?" Label="@L["Filter_AmountFrom"]"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Class="w-100"
                             Value="MinAmount"
                             ValueChanged="OnMinAmountChanged"
                             Clearable="true" />

            <MudNumericField T="decimal?" Label="@L["Filter_AmountTo"]"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Class="w-100"
                             Value="MaxAmount"
                             ValueChanged="OnMaxAmountChanged"
                             Clearable="true" />

            <MudDivider Class="my-2" />

            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Disabled="Busy"
                           OnClick="OnClearClicked">
                    @L["Filter_Clear"]
                </MudButton>

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Disabled="Busy"
                           OnClick="OnResetClicked">
                    @L["Filter_Reset"]
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="Busy"
                           OnClick="OnSaveClicked">
                    @L["Filter_Save"]
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
}