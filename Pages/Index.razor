@page "/"

<PageTitle>PersonalCash</PageTitle>

<MudContainer Class="pa-6" MaxWidth="MaxWidth.Medium">
    <MudText Typo="Typo.h5">PersonalCash</MudText>
    <MudText Typo="Typo.body1" Class="mt-2">
        Personal transactions tracker.
    </MudText>

    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <AuthorizeView>

            <Authorized>
                <MudText Typo="Typo.subtitle1">You are signed in.</MudText>
                <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" Href="transactions">
                    Open transactions
                </MudButton>
            </Authorized>

            <NotAuthorized>
                <MudText Typo="Typo.subtitle1">You are not signed in.</MudText>
                <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" Href="login">
                    Login
                </MudButton>
            </NotAuthorized>

        </AuthorizeView>
    </MudPaper>
</MudContainer>
