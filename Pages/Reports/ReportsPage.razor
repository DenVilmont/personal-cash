@page "/reports"
@inherits PersonalCash.Shared.UiComponentBase

@using Domain.Enums
@using PersonalCash.Pages.Reports.Components

<div>
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-6">
        <MudStack Spacing="3">
            <ReportsSummaryPanel Busy="_busy"
                                 Income="_summaryIncome"
                                 Expenses="_summaryExpenses"
                                 Balances="_summaryBalance" />

            <MudTabs Rounded="true"
                     ApplyEffectsToContainer="true"
                     Elevation="1"
                     TabPanelsClass="pa-4">

                <MudTabPanel Text="@L["Reports_TabCategories"]">
                    <MudStack Spacing="3">

                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="12" sm="6" md="3">
                                    <MudDatePicker Label="@L["Filter_Date_From"]"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Class="w-100"
                                                   @bind-Date="PrimaryFromDateTime"
                                                   @bind-Date:after="ApplyPrimaryFilters"
                                                   Clearable="true" />
                                </MudItem>

                                <MudItem xs="12" sm="6" md="3">
                                    <MudDatePicker Label="@L["Filter_Date_To"]"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Class="w-100"
                                                   @bind-Date="PrimaryToDateTime"
                                                   @bind-Date:after="ApplyPrimaryFilters"
                                                   Clearable="true" />
                                </MudItem>

                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="DateOnly?"
                                               Label="@L["Filter_Month"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               @bind-Value="_primaryMonth"
                                               @bind-Value:after="ApplyPrimaryFilters"
                                               Clearable="true"
                                               OnClearButtonClick="ClearPrimaryDates">
                                        <MudSelectItem Value="@((DateOnly?)null)">
                                            @L["Filter_Month_All"]
                                        </MudSelectItem>

                                        @foreach (var month in _primaryMonthOptions)
                                        {
                                            <MudSelectItem Value="@((DateOnly?)month)">
                                                @month.ToString("MMMM yyyy", CultureInfo.CurrentUICulture)
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="Guid?"
                                               Label="@L["Filter_Account"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               @bind-Value="_primaryAccountId"
                                               @bind-Value:after="ApplyPrimaryFilters"
                                               Clearable="true"
                                               OnClearButtonClick="ApplyPrimaryFilters">
                                        <MudSelectItem Value="@((Guid?)null)">
                                            @L["Filter_Account_All"]
                                        </MudSelectItem>

                                        @foreach (var account in _accounts)
                                        {
                                            <MudSelectItem Value="@((Guid?)account.Id)">
                                                @account.Name
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12">
                                    <MudButton Variant="Variant.Outlined"
                                               Disabled="_busy"
                                               OnClick="ResetPrimaryFilters">
                                        @L["Filter_Reset"]
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>

                        <ReportsCategoryChart Busy="_busy"
                                              Total="_categoryTotal"
                                              Currency="_primaryReportCurrency"
                                              ChartSeries="_donutSeries"
                                              ChartLabels="_donutLabels"
                                              ChartOptions="_donutOptions"
                                              HasData="_categoryRows.Count > 0" />

                        <ReportsCategoryTable Busy="_busy"
                                              Rows="_categoryRows"
                                              Currency="_primaryReportCurrency" />
                    </MudStack>
                </MudTabPanel>

                <MudTabPanel Text="@L["Reports_TabLineChart"]">
                    <MudStack Spacing="3">

                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="12" md="4">
                                    <MudSelect T="DateOnly"
                                               Label="@L["Filter_Months"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               MultiSelection="true"
                                               SelectedValues="_trendSelectedMonths"
                                               SelectedValuesChanged="OnTrendMonthsChanged"
                                               ToStringFunc="@(m => m.ToString("MMMM yyyy", CultureInfo.CurrentUICulture))"
                                               MultiSelectionTextFunc="@(values => string.Join(", ", values))">
                                        @foreach (var month in _trendMonthOptions)
                                        {
                                            <MudSelectItem Value="@month">
                                                @month.ToString("MMMM yyyy", CultureInfo.CurrentUICulture)
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudSelect T="EntryType"
                                               Label="@L["Filter_Type"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               MultiSelection="true"
                                               SelectedValues="_trendSelectedTypes"
                                               SelectedValuesChanged="OnTrendTypesChanged"
                                               ToStringFunc="@(value => value.ToLocalizedString(L))"
                                               MultiSelectionTextFunc="@(values => string.Join(", ", values))">
                                        <MudSelectItem Value="@EntryType.Income">
                                            @EntryType.Income.ToLocalizedString(L)
                                        </MudSelectItem>
                                        <MudSelectItem Value="@EntryType.Outcome">
                                            @EntryType.Outcome.ToLocalizedString(L)
                                        </MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudSelect T="Guid"
                                               Label="@L["Filter_Categories"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               MultiSelection="true"
                                               SelectedValues="_trendSelectedCategoryIds"
                                               SelectedValuesChanged="OnTrendCategoriesChanged"
                                               Clearable="true"
                                               OnClearButtonClick="ClearTrendCategories"
                                               ToStringFunc="@(id => CategoryName(id))"
                                               MultiSelectionTextFunc="@(values => string.Join(", ", values))">
                                        @foreach (var category in _trendCategoryOptions)
                                        {
                                            <MudSelectItem Value="@category.Id">
                                                @category.Name
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudButton Variant="Variant.Outlined"
                                                   Disabled="_busy"
                                                   OnClick="ResetTrendFilters">
                                            @L["Filter_Reset"]
                                        </MudButton>

                                        <MudText Typo="Typo.caption">
                                            @L["Reports_LineChart_TrendHint"]
                                        </MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>

                        <ReportsMonthlyChart Busy="_busy"
                                             ChartSeries="_trendSeries"
                                             ChartLabels="_trendXAxisLabels"
                                             ChartOptions="_lineOptions"
                                             HasData="_trendSeries.Count > 0 && _trendXAxisLabels.Length > 0" />
                    </MudStack>
                </MudTabPanel>

                <MudTabPanel Text="@L["Reports_TabBarChart"]">
                    <MudStack Spacing="3">

                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="12" md="4">
                                    <MudSelect T="DateOnly"
                                               Label="@L["Filter_Months"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               MultiSelection="true"
                                               SelectedValues="_trendSelectedMonths"
                                               SelectedValuesChanged="OnTrendMonthsChanged"
                                               ToStringFunc="@(m => m.ToString("MMMM yyyy", CultureInfo.CurrentUICulture))"
                                               MultiSelectionTextFunc="@(values => string.Join(", ", values))">
                                        @foreach (var month in _trendMonthOptions)
                                        {
                                            <MudSelectItem Value="@month">
                                                @month.ToString("MMMM yyyy", CultureInfo.CurrentUICulture)
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudSelect T="EntryType"
                                               Label="@L["Filter_Type"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               MultiSelection="true"
                                               SelectedValues="_trendSelectedTypes"
                                               SelectedValuesChanged="OnTrendTypesChanged"
                                               ToStringFunc="@(value => value.ToLocalizedString(L))"
                                               MultiSelectionTextFunc="@(values => string.Join(", ", values))">
                                        <MudSelectItem Value="@EntryType.Income">
                                            @EntryType.Income.ToLocalizedString(L)
                                        </MudSelectItem>
                                        <MudSelectItem Value="@EntryType.Outcome">
                                            @EntryType.Outcome.ToLocalizedString(L)
                                        </MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudSelect T="Guid"
                                               Label="@L["Filter_Categories"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="w-100"
                                               MultiSelection="true"
                                               SelectedValues="_trendSelectedCategoryIds"
                                               SelectedValuesChanged="OnTrendCategoriesChanged"
                                               Clearable="true"
                                               OnClearButtonClick="ClearTrendCategories"
                                               ToStringFunc="@(id => CategoryName(id))"
                                               MultiSelectionTextFunc="@(values => string.Join(", ", values))">
                                        @foreach (var category in _trendCategoryOptions)
                                        {
                                            <MudSelectItem Value="@category.Id">
                                                @category.Name
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudButton Variant="Variant.Outlined"
                                                   Disabled="_busy"
                                                   OnClick="ResetTrendFilters">
                                            @L["Filter_Reset"]
                                        </MudButton>

                                        <MudText Typo="Typo.caption">
                                            @L["Reports_LineChart_TrendHint"]
                                        </MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>

                        <ReportsMonthlyBarChart Busy="_busy"
                                                ChartSeries="_trendSeries"
                                                ChartLabels="_trendXAxisLabels"
                                                ChartOptions="_barOptions"
                                                HasData="_trendSeries.Count > 0 && _trendXAxisLabels.Length > 0" />
                    </MudStack>
                </MudTabPanel>

            </MudTabs>

        </MudStack>
    </MudContainer>
</div>
