@inherits PersonalCash.Shared.UiComponentBase

@using Domain.Contracts

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">

            <MudTextField Label="@L["Debts_Name"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Required="true"
                          @bind-Value="_name" />

            <MudNumericField T="decimal"
                             Label="@L["Amount"]"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             @bind-Value="_amount"
                             @bind-Value:after="RebuildPreview"
                             HideSpinButtons="true"
                             Immediate="true"
                             Culture="CultureInfo.CurrentCulture"
                             Adornment="Adornment.Start"
                             AdornmentText="@_currency"
                             Disabled="@_amountLocked" />

            <MudNumericField T="int"
                             Label="@L["Debts_PaymentCount"]"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             @bind-Value="_paymentsCount"
                             @bind-Value:after="RebuildPreview"
                             Immediate="true"
                             Disabled="@_amountLocked" />

            <MudDatePicker Label="@L["Debts_FirstPaymentDate"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="w-100"
                           @bind-Date="StartDatePicker"
                           @bind-Date:after="RebuildPreview"
                           Clearable="false"
                           Disabled="@_amountLocked" />

            <MudSwitch T="bool"
                       Color="Color.Primary"
                       Label="@L["Debts_HasInterest"]"
                       @bind-Value="_hasInterest"
                       Disabled="@_amountLocked" />

            <MudTextField Label="@L["Note"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="5"
                          @bind-Value="_note" />

            @if (_amountLocked)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    @L["Debts_ScheduleEditLocked_Info"]
                </MudAlert>
            }

            @if (_previewPayments.Count > 0)
            {
                <MudDivider Class="my-2" />

                <MudText Typo="Typo.subtitle2">@L["Debts_SchedulePreview"]</MudText>

                <MudTable Items="@_previewPayments" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>@L["Date"]</MudTh>
                        <MudTh class="pc-text-align-right">@L["Amount"]</MudTh>
                    </HeaderContent>

                    <RowTemplate Context="payment">
                        <MudTd>@payment.DueDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd class="pc-text-align-right">@payment.Amount.ToString("N2")</MudTd>
                    </RowTemplate>
                </MudTable>
            }

        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">@L["Save"]</MudButton>
    </DialogActions>
</MudDialog>