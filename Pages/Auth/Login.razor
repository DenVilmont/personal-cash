@page "/login"
@inherits PersonalCash.Shared.UiComponentBase

@using Infrastructure.Auth
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="login-page">
    <MudPaper Elevation="5" Class="login-card">
        <form class="login-form" @onsubmit="OnSubmitLogin" @onsubmit:preventDefault="true">
            <MudText Typo="Typo.h4" Align="Align.Center" Class="login-title">@L["Welcome"]</MudText>

            <MudTextField Label="@L["Email"]"
                          @bind-Value="email"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="login-field" />

            <MudTextField Label="@L["Password"]"
                          @bind-Value="password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          InputType="InputType.Password"
                          Class="login-field" />

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Color="Color.Primary"
                       ButtonType="ButtonType.Submit"
                       Class="login-button">
                @L["Login"]
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       FullWidth="true"
                       Color="Color.Secondary"
                       ButtonType="ButtonType.Button"
                       Class="login-button"
                       OnClick="OnClickDemoLogin">
                @L["Demo_Login"]
            </MudButton>

            <MudText Class="login-link" Typo="Typo.body2">
                <MudLink Href="register">@L["Create_account"]</MudLink>
            </MudText>
        </form>
    </MudPaper>
</div>