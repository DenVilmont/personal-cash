@page "/login"
@inherits PersonalCash.Shared.UiComponentBase

@using Infrastructure.Auth
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<MudContainer Class="d-flex justify-center align-center" Style="height:100vh !important">
    <MudPaper Elevation="5" Class="pa-10" style="text-align:center">
        <MudContainer Class="d-flex flex-column justify-center" style="width: 450px">
            <MudText Typo="Typo.h5">@L["Welcome"]</MudText>
            <br>
            <MudTextField Label=@L["Email"] @bind-Value="email" Variant="Variant.Outlined"></MudTextField>
            <MudTextField Label=@L["Password"] @bind-Value="password" Variant="Variant.Outlined" InputType="InputType.Password"></MudTextField>
            <br>
            <MudButton Variant="Variant.Filled" 
                       FullWidth="true" 
                       Color="Color.Primary"
                       Class="mt-2"
                       OnClick="OnClickLogin">
                            @L["Login"]
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       FullWidth="true" 
                       Color="Color.Secondary"
                       Class="mt-2"
                       OnClick="OnClickDemoLogin">
                            @L["Demo_Login"]
            </MudButton>

            <MudText Class="mt-4" Typo="Typo.body2">
                <MudLink Href="register">@L["Create_account"]</MudLink>
            </MudText>
        </MudContainer>
    </MudPaper>
</MudContainer>