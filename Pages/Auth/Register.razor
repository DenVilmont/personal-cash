@page "/register"
@inherits PersonalCash.Shared.UiComponentBase

@using Infrastructure.Auth
@inject AuthService Auth
@inject NavigationManager Nav

<MudContainer Class="d-flex justify-center align-center" Style="height:100vh !important">
    <MudPaper Elevation="5" Class="pa-10" style="text-align:center">
        <MudContainer Class="d-flex flex-column justify-center" style="width: 450px">
            <MudText Typo="Typo.h5">Create account</MudText>
            <br>

            <MudTextField Label=@L["Email"]
                          @bind-Value="email" 
                          InputMode="InputMode.email"
                          Variant="Variant.Outlined"/>

            <MudTextField Label="@L["Password"]"
                          @bind-Value="password"
                          InputType="@PasswordInput"
                          Adornment="Adornment.End"
                          AdornmentIcon="@PasswordInputIcon"
                          OnAdornmentClick="TogglePassword"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="w-100" />

            <br>

            <MudButton Variant="Variant.Filled"
                       FullWidth
                       Color="Color.Primary"
                       Disabled="@_busy"
                       OnClick="OnRegister">
                @L["Create_account"]
            </MudButton>

            <MudButton Class="mt-2"
                       Variant="Variant.Outlined"
                       FullWidth
                       Disabled="@_busy"
                       OnClick="@(() => Nav.NavigateTo("login"))">
                @L["Back"]
            </MudButton>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <MudAlert Class="mt-4" Severity="Severity.Info" Variant="Variant.Outlined">
                    @message
                </MudAlert>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <MudAlert Class="mt-4" Severity="Severity.Error" Variant="Variant.Outlined">
                    @error
                </MudAlert>
            }
        </MudContainer>
    </MudPaper>
</MudContainer>
