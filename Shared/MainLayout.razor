@inherits LayoutComponentBase


<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@(_ => DrawerToggle())" />

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudMenu AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight"
                         Dense="true">

                    <ActivatorContent Context="menuCtx">
                        <MudButton Variant="Variant.Text" 
                                   Color="Color.Inherit" 
                                   OnClick="@menuCtx.ToggleAsync">
                            <MudAvatar Size="Size.Medium" Class="mr-2">
                                @if (!string.IsNullOrWhiteSpace(AvatarSrc))
                                {
                                    <MudImage Src="@AvatarSrc"></MudImage>
                                }
                                else
                                {
                                    <MudIcon Color="Color.Dark" Icon="@Icons.Custom.Uncategorized.Radioactive" Size="Size.Large" />
                                }
                            </MudAvatar>

                            <MudText Typo="Typo.body2" Class="mr-1">@DisplayName</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" />
                        </MudButton>
                    </ActivatorContent>

                    <ChildContent>
                        <MudMenuItem Href="settings" Icon="@Icons.Material.Filled.Settings">
                            @L["Settings"]
                        </MudMenuItem>

                        <MudMenuItem OnClick="OnClickLogout" Icon="@Icons.Material.Filled.Logout">
                            @L["Logout"]
                        </MudMenuItem>
                    </ChildContent>

                </MudMenu>
            </Authorized>

            <NotAuthorized>
                <MudButton Color="Color.Tertiary" Href="login">@L["Login"]</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <AuthorizeView>
        <MudDrawer @bind-Open="_drawerOpen"
                   Variant="DrawerVariant.Temporary"
                   Overlay="true"
                   Elevation="2">
            <MudDrawerHeader>
                <MudText Typo="Typo.h5" Class="mt-1">PersonalCash</MudText>
            </MudDrawerHeader>

            <MudNavMenu Color="Color.Secondary">
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
                    Home
                </MudNavLink>
                <MudNavLink Href="transactions" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Storage">
                    Transactions
                </MudNavLink>
                <MudNavLink Href="reports" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.QueryStats">
                    Reports
                </MudNavLink>
                <MudNavLink Href="debts" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.RequestQuote">
                    Debts
                </MudNavLink>
                <MudNavLink Href="accounts" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Storage">
                    Accounts
                </MudNavLink>
                <MudNavLink Href="categories" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Storage">
                    Categories
                </MudNavLink>
            </MudNavMenu>
        </MudDrawer>
    </AuthorizeView>
        <MudMainContent Class="d-flex flex-column" Style="height:100vh !important">
            @Body
        </MudMainContent>
</MudLayout>